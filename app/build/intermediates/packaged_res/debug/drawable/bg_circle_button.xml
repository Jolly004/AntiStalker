<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ring (Stroke) -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#4040E0D0" /> <!-- Transparent Mint -->
            <solid android:color="@android:color/transparent" />
            <size android:width="168dp" android:height="168dp"/>
        </shape>
    </item>
    
    <!-- Inner Solid Circle -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="@color/accent" />
            <gradient
                android:startColor="#40E0D0"
                android:endColor="#00C853"
                android:angle="45"
                android:type="linear" />
            <elevation android:elevation="8dp" />
        </shape>
    </item>
</layer-list>
